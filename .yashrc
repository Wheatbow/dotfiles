#!/bin/sh
#shellcheck disable=SC3043

export PS1
PS1='${${?:/0/\\fg}/#[1-9]/\\fr}${$(pwd)/~/\~}\$ '

_autocd() {
	if [ -d "$1" ]; then
		export HANDLED=true
		# shellcheck disable=SC2164
  	cd -- "$@"
	fi
}
export COMMAND_NOT_FOUND_HANDLER='_autocd "$@"'

alias mkdir="mkdir -p"
alias rm="rm -Ir"
alias cp="cp -i"
alias mv="mv -i"
alias ls="ls -alh --color=auto --group-directories-first"
alias du="du -h"
alias df="df -h"
alias free="free -m"
alias pcpu='ps u -u "$USER" --sort=-pcpu'
alias pmem='ps u -u "$USER" --sort=-pmem'
alias paci="doas pacman -S"
alias pacr="doas pacman -Rsn"
alias pacu="doas pacman -Syu"
alias mount="udisksctl mount -b"
alias umount="udisksctl unmount -b"
alias loop="udisksctl loop-setup -rf"
alias uloop="udisksctl loop-delete -b"
alias -g hx="helix"

_basename() {
	if [ "$#" -eq 0 ]; then
		printf "basename: missing operand\n"
		return 1
	fi
	for in in "$@"; do
		while true; do
			local head
			head="${in%/*}"
			local tail
			tail="${in#"$head"}"
			if [ "$tail" != "/" ]; then
				if [ -n "$tail" ]; then
					printf "%s\n" "${tail#/}"
				else
					printf "%s\n" "$head"
				fi
				break
			elif [ -z "$head" ]; then
				printf "%s\n" "$tail"
				break
			fi
			in="$head"
		done
	done
}

_dirname() {
	if [ "$#" -eq 0 ]; then
		printf "dirname: missing operand\n"
		return 1
	fi
	for in in "$@"; do
		while true; do
			local head
			head="${in%/*}"
			local tail
			tail="${in#"$head"}"
			if [ "$tail" != "/" ]; then
				if [ -z "$tail" ]; then
					printf ".\n"
				else
					in="$head"
					while true; do
						head="${in%/*}"
						tail="${in#"$head"}"
						if [ "$tail" != "/" ]; then
							printf "%s\n" "$head$tail"
							break
						fi
						in="$head"
					done
					break
				fi
				break
			elif [ -z "$head" ]; then
				printf "%s\n" "$tail"
				break
			fi
			in="$head"
		done
	done
}

_realpath() {
	if [ "$#" -eq 0 ]; then
		printf "realpath: missing operand\n"
		return 1
	fi
	for in in "$@"; do
		local out
		local component
		component="${in%/"${in#*/}"}"
		if [ -n "$component" ]; then
			out="$(pwd)"
		else
			out=
  	fi
		while true; do
			if [ -n "$component" ] && [ "$component" != '.' ]; then
				if [ "$component" = '..' ]; then
					out="${out%/*}"
				else
					out="$out/$component"
				fi
			fi
			in="${in#*/}"
			if [ "$in" = "$component" ]; then
				if [ -n "$out" ]; then
					printf "%s\n" "$out"
				else
					printf "/\n"
				fi
				break
			fi
			component="${in%/"${in#*/}"}"
		done
	done
}

agenda() {
	if [ "$#" -lt 2 ]; then
		printf "agenda: missing operand\n"
		return 1
	fi
	local command
	command="$1"
	local path
	path="$(_realpath "$2")"
	case "$command" in
		create)
			if [ -e "$path" ]; then
				printf "agenda create %s: directory already exist\n" "$path"
				return 1
			fi
			temp="$(mktemp -d XXXXXXXXXXXXXXXX --tmpdir)"
			trap 'rm -rf "$temp"' EXIT
			local identity
			IFS="" identity="$(age-keygen 2> /dev/null)"
			local recipient
			recipient="$(echo "$identity" | age-keygen -y)"
			printf "Choose a password for protecting your files.\n"
			if ! echo "$identity" | age -e -p -o "$temp/identity.age"; then
				rm -rf "$temp"
				return 1
			fi
			unset identity
			mkdir -p "$temp/protected/content"
			echo "$recipient" > "$temp/protected/recipient"
			tar -c --zstd -C "$temp" "protected" | age -e -r "$recipient" -o "$temp/protected.age"
			mkdir -p "$path"
			cp "$temp/identity.age" "$temp/protected.age" "$path"
			rm -rf "$temp"
			git -C "$path" init
			;;
		shell|edit)
			if [ ! -d "$path" ]; then
				printf "agenda %s %s: no such directory\n" "$command" "$path"
				return 1
			elif [ ! -f "$path/identity.age" ]; then
				printf "agenda %s %s: missing identity.age\n" "$command" "$path"
				return 1
			elif [ ! -f "$path/protected.age" ]; then
				printf "agenda %s %s: missing protected.age\n" "$command" "$path"
				return 1
			fi
			temp="$(mktemp -d XXXXXXXXXXXXXXXX --tmpdir)"
			trap 'rm -rf "$temp"' EXIT
			if ! age -d -i "$path/identity.age" "$path/protected.age" | tar -x --zstd -C "$temp"; then
				rm -rf "$temp"
				return 1
			fi
			local pipe
			pipe="$temp/pipe"
			mkfifo "$pipe"
			inotifywait -m -q -r -e create -e delete -e modify -e move -o "$pipe" "$temp/protected/content" &
			local pid
			pid=$!
			{ while read -r _event; do
					tar -c --zstd -C "$temp" "protected" | age -e -R "$temp/protected/recipient" -o "$path/protected.age"
			  done < "$pipe" 
			} &
			case "$command" in
				edit) "$EDITOR" "$temp/protected/content" ;;
				shell) yash -c "cd $temp/protected/content;$SHELL" ;;
			esac
			kill "$pid"
			wait 1> /dev/null
			rm -rf "$temp"
			if [ -n "$(git -C "$path" status --porcelain)" ]; then
				git -C "$path" add --all || return
				printf "Committing changes...\n"
				git -C "$path" commit --allow-empty-message --no-edit || return
				printf "Pushing changes...\n"
				git -C "$path" push || return
			fi
			;;
		*)
			printf "agenda %s %s: invalid command\n" "$command" "$path"
			return 1
	esac
}

bottle() {
	if [ "$#" -lt 2 ]; then
		printf "bottle: missing operand\n"
		return 1
	fi
	local command
	command="$1"
	local path
	path="$(_realpath "$2")"
	local prefix
	prefix="$path/.wine"
	case "$command" in
		create)
			if [ -e "$path" ]; then
				printf "bottle create %s: file or directory already exist\n" "$path"
				return 1
			fi
			mkdir -p "$prefix"
			WINEPREFIX="$prefix" WINEDEBUG="-all" wineboot -i
			;;
		config|start|stop|kill)
			local root
			while true; do
				local head
				head="${prefix%/*}"
				local tail
				tail="${prefix#"$head"}"
				if [ "$tail" = "/.wine" ]; then
					if [ ! -f "$prefix/drive_c/windows/system32/kernel32.dll" ]; then
						printf "bottle %s %s: invalid .wine directory\n" "$command" "$path"
						return 1
					fi
					root="$head"
					break
				elif [ -z "$head" ]; then
					printf "bottle %s %s: missing .wine directory\n" "$command" "$path"
					return 1
				fi
				prefix="$head"
			done
			case "$command" in
				start)
					if [ -d "$path" ]; then
						if [ ! -f "$path/default.shortcut" ]; then
							printf "bottle start %s: missing default.shortcut\n" "$path"
							return 1
						fi
						local shortcut
						read -r shortcut < "$path/default.shortcut"
						WINEPREFIX="$prefix" WINEDEBUG="-all" wine start "$shortcut" 2> /dev/null
					elif [ -f "$path" ]; then
						if [ $path != ${path%shortcut} ]; then
							local shortcut
							read -r shortcut < "$path"
							WINEPREFIX="$prefix" WINEDEBUG="-all" wine start "$shortcut" 2> /dev/null
						else
							WINEPREFIX="$prefix" WINEDEBUG="-all" wine start /unix "$path" 2> /dev/null
						fi
					else
						printf "bottle start %s: no such file or directory\n" "$path"
					fi
					;;
				config)
					WINEPREFIX="$prefix" WINEDEBUG="-all" winecfg 2> /dev/null
					;;
				stop)
					WINEPREFIX="$prefix" WINEDEBUG="-all" wineboot -e
					;;
				kill)
					WINEPREFIX="$prefix" WINEDEBUG="-all" wineboot -ki
					;;
			esac
			;;
		*)
			printf "bottle %s %s: invalid command\n" "$command" "$path"
			return 1
	esac
}
