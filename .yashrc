. --autoload --no-alias initialization/common
unset HISTFILE

alias ls="ls -alh"
alias du="du -h"
alias df="df -h"
alias free="free -m"
alias pcpu="ps u -u $USER --sort=-pcpu"
alias pmem="ps u -u $USER --sort=-pmem"
alias aa="doas apk add"
alias ad="doas apk del"
alias af="doas apk fix"
alias au="doas apk update"
alias ai="doas apk info"
alias as="doas apk search"
alias auu="doas apk upgrade"
alias ac="doas apk cache"
alias av="doas apk version"
alias mount="udisksctl mount -b"
alias umount="udisksctl unmount -b"
alias loop="udisksctl loop-setup -rf"
alias uloop="udisksctl loop-delete -b"
alias pn="pnpm"

sf () {
	if [ ! -e $1 ]; then
		mkdir $1
		gocryptfs -init -xchacha $1
		if [ $? -ne 0 ]; then
			rmdir $1
			return 1
		fi
	fi
	local temp=$(mktemp -d XXXXXXXXXXXXXXXX --tmpdir)
	trap 'rmdir $temp' 0 2 3 15
	gocryptfs -q $1 $temp
	if [ $? -ne 0 ]; then
		rmdir $temp
		return 1
	fi
	trap 'fusermount -uq $temp' 0 2 3 15
	if [ -z ${2+x} ]; then
		yash -c "cd $temp;$SHELL"
	else
		$2 $temp
	fi
	fusermount -uq $temp
	rmdir $temp
}

sfhx () {
	sf $1 hx
}
